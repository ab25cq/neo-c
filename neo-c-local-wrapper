#!/usr/bin/env bash

CC=clang
CFLAGS=-Os
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
NCC_BIN="ncc"
if [ -x "$SCRIPT_DIR/ncc" ]; then
  NCC_BIN="$SCRIPT_DIR/ncc"
fi

files=()
opts=()
ncc_opts=()
libs=()
obj_files=()
target=""
no_rm_pp=true

expect_target=false
compile_only=false
all_object_file=true
m5stack=false
pico=false
portable_c_disabled=false

for arg in "$@"; do
  if [ "$expect_target" = true ]; then
    target="$arg"
    expect_target=false
    continue
  fi

  case "$arg" in
    -E)
      no_rm_pp=false
      ;;
    -gcc)
      CC=gcc
      ;;
    -pico)
      opts+=("-D__PICO__")
      pico=true
      ;;
    -m5stack)
      opts+=("-m5stack")
      opts+=("-D__M5STACK__")
      opts+=("-cpp")
      opts+=("-uniq")
      m5stack=true
      ;;
    -uniq)
        opts+=("-uniq")
        ;;
    -cpp)
      CC=clang++
      ;;
    -portable-c)
      ncc_opts+=("-portable-c")
      ;;
    -no-portable-c)
      portable_c_disabled=true
      ;;
    -o)
      expect_target=true
      ;;
    -c)
      compile_only=true
      ;;
    -l*)
      libs+=("$arg")
      ;;
    -*)
      opts+=("$arg")
      ;;
    *.o)
      obj_files+=("$arg")
      ;;
    *.nc)
      files+=("$arg")
      all_object_file=false
      ;;
    *)
      files+=("$arg")
      all_object_file=false
      ;;
  esac
done

if [ "$(uname -s 2>/dev/null)" = "Darwin" ] \
  && [ "$portable_c_disabled" = false ] \
  && [ "$all_object_file" = false ]; then
  has_portable=false
  for opt in "${ncc_opts[@]}"; do
    if [ "$opt" = "-portable-c" ]; then
      has_portable=true
      break
    fi
  done

  if [ "$has_portable" = false ]; then
    ncc_opts+=("-portable-c")
  fi
fi

# base for output/error path (keeps source directory)
base="${files[0]%.nc}"
# ncc writes transpiled C into current directory using basename
cbase="$(basename "${base}")"
srcdir="$(cd "$(dirname "${files[0]}")" && pwd)"

include_opts=()
if [ -d "$srcdir" ]; then
  include_opts+=("-I${srcdir}")
fi
if [ -d "$SCRIPT_DIR" ] && [ "$SCRIPT_DIR" != "$srcdir" ]; then
  include_opts+=("-I${SCRIPT_DIR}")
fi

if [ "$CC" = clang++ ]
then
    "$NCC_BIN" "${include_opts[@]}" "${opts[@]}" "${ncc_opts[@]}" -cpp "${files[0]}"
else
    "$NCC_BIN" "${include_opts[@]}" "${opts[@]}" "${ncc_opts[@]}" "${files[0]}"
fi

transpile_ok=$?

if [ "$pico" = true ]
then
    echo pico
    exit 0
elif [ "$m5stack" = true ]
then
    echo m5stack
    exit 0
elif [ "$all_object_file" = true ]
then
    $NCC_BIN /usr/local
    $CC "${opts[@]}" -o "${target}" "${files[@]}" $CFLAGS -L/opt/homebrew/opt/openssl/lib -L/opt/homebrew/opt/boehmgc/lib -L/opt/homebrew/opt/zstd/lib -I/opt/homebrew/opt/openssl/include -L/opt/homebrew/opt/ncurses/lib "${obj_files[@]}" "${libs[@]}" /usr/local/lib/neo-c-str.o
    echo $CC "${opts[@]}" -o "${target}" "${files[@]}" $CFLAGS -L/opt/homebrew/opt/openssl/lib -L/opt/homebrew/opt/boehmgc/lib -L/opt/homebrew/opt/zstd/lib -I/opt/homebrew/opt/openssl/include -L/opt/homebrew/opt/ncurses/lib "${obj_files[@]}" "${libs[@]}" /usr/local/lib/neo-c-str.o
elif test $transpile_ok = 0
then
    neo_c_str_obj="/usr/local/lib/neo-c-str.o"
    if [ -f "$SCRIPT_DIR/neo-c-str.o" ]; then
        neo_c_str_obj="$SCRIPT_DIR/neo-c-str.o"
    fi
    if test $compile_only = true
    then
        if test -z "$target"
        then
            target=${base}.o
        fi

        echo $CC $CFLAGS -L/opt/homebrew/opt/openssl/lib -L/opt/homebrew/opt/boehmgc/lib -L/opt/homebrew/opt/zstd/lib -I/opt/homebrew/opt/openssl/include -L/opt/homebrew/opt/ncurses/lib -c "${opts[@]}" -o "${target}" "${cbase}.c" "${libs[@]}" "$neo_c_str_obj"
        if $CC $CFLAGS -L/opt/homebrew/opt/openssl/lib -L/opt/homebrew/opt/boehmgc/lib -L/opt/homebrew/opt/zstd/lib -I/opt/homebrew/opt/openssl/include -L/opt/homebrew/opt/ncurses/lib -c "${opts[@]}" -o "${target}" "${cbase}.c" "${libs[@]}" "$neo_c_str_obj" 2> "${base}.c.error"
        then
            rm -f "${base}.c.error"
            if test $no_rm_pp = true
            then
                rm -f "${base}.nc.i"
            fi
        else
            cat "${base}.c.error" | grep error; exit 3
        fi
    else
        if test -z "$target"
        then
            target=${base}
        fi

        echo $CC $CFLAGS -L/opt/homebrew/opt/openssl/lib -L/opt/homebrew/opt/boehmgc/lib -L/opt/homebrew/opt/zstd/lib -I/opt/homebrew/opt/openssl/include "${opts[@]}" -L/opt/homebrew/opt/ncurses/lib -o "${target}" "${cbase}.c" "${obj_files[@]}" "${libs[@]}" "$neo_c_str_obj"
        if $CC $CFLAGS -L/opt/homebrew/opt/openssl/lib -L/opt/homebrew/opt/boehmgc/lib -L/opt/homebrew/opt/zstd/lib -I/opt/homebrew/opt/openssl/include "${opts[@]}" -L/opt/homebrew/opt/ncurses/lib -o "${target}" "${cbase}.c" "${obj_files[@]}" "${libs[@]}" "$neo_c_str_obj" 2> "${base}.c.error"
        then
            rm -f "${base}.c.error"
            if test $no_rm_pp = true
            then
                rm -f "${base}.nc.i"
            fi
        else
            cat "${base}.c.error" | grep error; exit 3
        fi
    fi
fi
