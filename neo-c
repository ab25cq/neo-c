#!/usr/bin/env bash

CC=clang

link_gc_sections="-Wl,--gc-sections"
if [ "$(uname -s 2>/dev/null)" = "Darwin" ]; then
  link_gc_sections="-Wl,-dead_strip"
fi

CFLAGS="-Oz -ffunction-sections -fdata-sections ${link_gc_sections} -flto=thin"
#CFLAGS="-Os -ffunction-sections -fdata-sections ${link_gc_sections} -flto=thin"
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
NCC_BIN="ncc"
if [ -x "$SCRIPT_DIR/ncc" ]; then
  NCC_BIN="$SCRIPT_DIR/ncc"
fi

default_neo_c_str_args=()
if [ -f "$SCRIPT_DIR/neo-c-str.o" ]; then
  default_neo_c_str_args+=("$SCRIPT_DIR/neo-c-str.o")
elif [ -f /usr/local/lib/neo-c-str.o ]; then
  default_neo_c_str_args+=("/usr/local/lib/neo-c-str.o")
fi

files=()
opts=()
ncc_opts=()
libs=()
obj_files=()
target=""
no_rm_pp=true
bare=false

expect_target=false
compile_only=false
all_object_file=true
m5stack=false
pico=false
no_compile=false
micro=false
portable_c_disabled=false

for arg in "$@"; do
  if [ "$expect_target" = true ]; then
    target="$arg"
    expect_target=false
    continue
  fi

  case "$arg" in
    -E)
      no_rm_pp=false
      ;;
    -micro)
      bare=true
      opts+=("-D__NEO_MICRO__")
      opts+=("-D__BAREMETAL__")
      ncc_opts+=("-micro")
      ncc_opts+=("-bare")
      ncc_opts+=("-D__NEO_MICRO__")
      micro=true
      ;;
    -S)
      no_compile=true
      ;;
    -s)
      no_compile=true
      ;;
    -gcc)
      CC=gcc
      ;;
    -pico)
      opts+=("-D__PICO__")
      ncc_opts+=("-D__PICO__")
      pico=true
      ;;
    -m5stack)
      opts+=("-D__M5STACK__")
      m5stack=true
      ;;
    -uniq)
        opts+=("-uniq")
        ;;
    -cpp)
      CC=clang++
      ;;
    -portable-c)
      ncc_opts+=("-portable-c")
      ;;
    -bare)
      bare=true
      opts+=("-D__BAREMETAL__")
      ncc_opts+=("-bare")
      ;;
    -no-portable-c)
      portable_c_disabled=true
      ;;
    -o)
      expect_target=true
      ;;
    -c)
      compile_only=true
      ;;
    -l*)
      libs+=("$arg")
      ;;
    -*)
      opts+=("$arg")
      ;;
    *.o)
      obj_files+=("$arg")
      ;;
    *.nc)
      files+=("$arg")
      all_object_file=false
      ;;
    *)
      files+=("$arg")
      all_object_file=false
      ;;
  esac
done

if [ "$(uname -s 2>/dev/null)" = "Darwin" ] \
  && [ "$portable_c_disabled" = false ] \
  && [ "$all_object_file" = false ]; then
  has_portable=false
  for opt in "${ncc_opts[@]}"; do
    if [ "$opt" = "-portable-c" ]; then
      has_portable=true
      break
    fi
  done

  if [ "$has_portable" = false ]; then
    ncc_opts+=("-portable-c")
  fi
fi

bare_link_opts=()
bare_cflags=()
object_link_neo_c_str_args=("${default_neo_c_str_args[@]}")
if [ "$bare" = true ]; then
  bare_link_opts+=("-nostdlib")
  if [ "$(uname -s 2>/dev/null)" = "Darwin" ]; then
    bare_link_opts+=("-Wl,-e,_main")
    bare_link_opts+=("-lSystem")
  else
    bare_link_opts+=("-Wl,-e,_start")
  fi
  bare_cflags+=("-fno-stack-protector")
  object_link_neo_c_str_args=()
fi

# base for output/error path (keeps source directory)
base="${files[0]%.nc}"
# ncc writes transpiled C into current directory using basename
cbase="$(basename "${base}")"
srcdir="$(cd "$(dirname "${files[0]}")" && pwd)"

include_opts=()
if [ -d "$srcdir" ]; then
  include_opts+=("-I${srcdir}")
fi
if [ -d "$SCRIPT_DIR" ] && [ "$SCRIPT_DIR" != "$srcdir" ]; then
  include_opts+=("-I${SCRIPT_DIR}")
fi

if [ "$CC" = clang++ ]
then
    "$NCC_BIN" "${include_opts[@]}" "${opts[@]}" -ffunction-sections -fdata-sections "${link_gc_sections}" -flto=thin "${ncc_opts[@]}" -cpp "${files[0]}"
else
    "$NCC_BIN" "${include_opts[@]}" -ffunction-sections -fdata-sections "${link_gc_sections}" -flto=thin "${opts[@]}" "${ncc_opts[@]}" "${files[0]}"
fi

transpile_ok=$?

neo_c_str_args=()
regex_runtime_pattern='string_scan|string_match|charp_scan|charp_match|charp_index_regex|string_index_regex|charp_split|string_split|re_match'
if [ -f "${cbase}.c" ]; then
  link_neo_c_str=false
  if command -v rg >/dev/null 2>&1; then
    if rg -q "$regex_runtime_pattern" "${cbase}.c"; then
      link_neo_c_str=true
    fi
  elif grep -Eq "$regex_runtime_pattern" "${cbase}.c"; then
    link_neo_c_str=true
  fi

  if [ "$bare" = false ] && [ "$link_neo_c_str" = true ]; then
    neo_c_str_args=("${default_neo_c_str_args[@]}")
  fi
fi

strip_output_executable()
{
  local output="$1"

  if [ -n "$output" ] && [ -f "$output" ] && command -v strip >/dev/null 2>&1; then
    strip "$output" 2>/dev/null || true
  fi
}

if [ "$pico" = true ]
then
    exit 0
elif [ "$m5stack" = true ]
then
    exit 0
elif [ "$micro" = true ]
then
    exit 0
elif [ "$no_compile" = true ]
then
    exit 0
elif [ "$all_object_file" = true ]
then
    $NCC_BIN /usr/local
    if $CC -ffunction-sections -fdata-sections "${link_gc_sections}" -flto=thin "${opts[@]}" -o "${target}" "${files[@]}" $CFLAGS "${bare_cflags[@]}" -L/opt/homebrew/opt/openssl/lib -L/opt/homebrew/opt/boehmgc/lib -L/opt/homebrew/opt/zstd/lib -I/opt/homebrew/opt/openssl/include -L/opt/homebrew/opt/ncurses/lib "${bare_link_opts[@]}" "${obj_files[@]}" "${libs[@]}" "${object_link_neo_c_str_args[@]}"
    then
        strip_output_executable "${target}"
    else
        exit 3
    fi
    echo $CC -ffunction-sections -fdata-sections "${link_gc_sections}" -flto=thin "${opts[@]}" -o "${target}" "${files[@]}" $CFLAGS "${bare_cflags[@]}" -L/opt/homebrew/opt/openssl/lib -L/opt/homebrew/opt/boehmgc/lib -L/opt/homebrew/opt/zstd/lib -I/opt/homebrew/opt/openssl/include -L/opt/homebrew/opt/ncurses/lib "${bare_link_opts[@]}" "${obj_files[@]}" "${libs[@]}" "${object_link_neo_c_str_args[@]}"
elif test $transpile_ok = 0
then
    if test $compile_only = true
    then
        if test -z "$target"
        then
            target=${base}.o
        fi

        echo $CC $CFLAGS "${bare_cflags[@]}" -L/opt/homebrew/opt/openssl/lib -L/opt/homebrew/opt/boehmgc/lib -L/opt/homebrew/opt/zstd/lib -I/opt/homebrew/opt/openssl/include -L/opt/homebrew/opt/ncurses/lib -c "${opts[@]}" -ffunction-sections -fdata-sections "${link_gc_sections}" -flto=thin -o "${target}" "${cbase}.c" "${libs[@]}"
        if $CC $CFLAGS "${bare_cflags[@]}" -L/opt/homebrew/opt/openssl/lib -L/opt/homebrew/opt/boehmgc/lib -L/opt/homebrew/opt/zstd/lib -I/opt/homebrew/opt/openssl/include -L/opt/homebrew/opt/ncurses/lib -c "${opts[@]}" -ffunction-sections -fdata-sections "${link_gc_sections}" -flto=thin -o "${target}" "${cbase}.c" "${libs[@]}" 2> "${base}.c.error"
        then
            rm -f "${base}.c.error"
            if test $no_rm_pp = true
            then
                rm -f "${base}.nc.i"
            fi
        else
            cat "${base}.c.error" | grep error; exit 3
        fi
    else
        if test -z "$target"
        then
            target=${base}
        fi

        echo $CC $CFLAGS "${bare_cflags[@]}" -L/opt/homebrew/opt/openssl/lib -L/opt/homebrew/opt/boehmgc/lib -L/opt/homebrew/opt/zstd/lib -I/opt/homebrew/opt/openssl/include "${opts[@]}" -ffunction-sections -fdata-sections "${link_gc_sections}" -flto=thin -L/opt/homebrew/opt/ncurses/lib "${bare_link_opts[@]}" -o "${target}" "${cbase}.c" "${obj_files[@]}" "${libs[@]}" "${neo_c_str_args[@]}"
        if $CC $CFLAGS "${bare_cflags[@]}" -L/opt/homebrew/opt/openssl/lib -L/opt/homebrew/opt/boehmgc/lib -L/opt/homebrew/opt/zstd/lib -I/opt/homebrew/opt/openssl/include "${opts[@]}" -ffunction-sections -fdata-sections "${link_gc_sections}" -flto=thin -L/opt/homebrew/opt/ncurses/lib "${bare_link_opts[@]}" -o "${target}" "${cbase}.c" "${obj_files[@]}" "${libs[@]}" "${neo_c_str_args[@]}" 2> "${base}.c.error"
        then
            strip_output_executable "${target}"
            rm -f "${base}.c.error"
            if test $no_rm_pp = true
            then
                rm -f "${base}.nc.i"
            fi
        else
            cat "${base}.c.error" | grep error; exit 3
        fi
    fi
fi
